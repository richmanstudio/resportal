{
  "name": "@resportal/api",
  "version": "0.1.0",
  "private": true,
  "main": "dist/server.js",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "prebuild": "npm --workspace @resportal/shared run build",
    "build": "prisma generate && tsc -p tsconfig.json",
    "pretypecheck": "npm --workspace @resportal/shared run build",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test:smoke": "tsx src/tests/smoke.ts",
    "test:integration": "tsx src/tests/integration.ts",
    "prisma:generate": "prisma generate",
    "prisma:migrate": "prisma migrate dev",
    "prisma:deploy": "prisma migrate deploy"
  },
  "dependencies": {
    "@prisma/client": "^6.8.2",
    "@resportal/shared": "0.1.0",
    "bcryptjs": "^3.0.2",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^5.1.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "redis": "^4.7.1",
    "zod": "^3.25.32"
  },
  "devDependencies": {
    "@types/cookie-parser": "^1.4.8",
    "@types/cors": "^2.8.18",
    "@types/express": "^5.0.2",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/node": "^22.15.21",
    "prisma": "^6.8.2",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
